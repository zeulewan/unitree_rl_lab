<?xml version="1.0"?>
<robot name="active_manual_wheelchair_x_rail">
  <!--
    Passive manual wheelchair wrapper.

    The detailed Free3D OBJ is visual-only. Physics uses primitive collisions
    so Isaac/PhysX gets stable mass, wheel joints, and handle frames.
  -->

  <material name="black">
    <color rgba="0.02 0.02 0.025 1.0"/>
  </material>
  <material name="purple">
    <color rgba="0.18 0.04 0.55 1.0"/>
  </material>
  <material name="metal">
    <color rgba="0.78 0.78 0.72 1.0"/>
  </material>

  <link name="rail_world">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.001"/>
      <inertia ixx="0.000001" ixy="0.0" ixz="0.0" iyy="0.000001" iyz="0.0" izz="0.000001"/>
    </inertial>
  </link>

  <joint name="rail_x_joint" type="prismatic">
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <parent link="rail_world"/>
    <child link="base_link"/>
    <axis xyz="1 0 0"/>
    <limit lower="-1000.0" upper="1000.0" effort="500.0" velocity="4.0"/>
    <dynamics damping="20.0" friction="0.5"/>
  </joint>

  <link name="base_link">
    <inertial>
      <origin xyz="0.00 0.00 0.48" rpy="0 0 0"/>
      <mass value="12.0"/>
      <inertia ixx="1.11" ixy="0.0" ixz="0.0" iyy="1.45" iyz="0.0" izz="0.94"/>
    </inertial>
    <visual name="free3d_active_wheelchair_visual">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="../visual/active_wheelchair.obj" scale="1 1 1"/>
      </geometry>
    </visual>
    <collision name="seat_collision">
      <origin xyz="0.05 0.00 0.48" rpy="0 0 0"/>
      <geometry>
        <box size="0.48 0.38 0.08"/>
      </geometry>
    </collision>
    <collision name="backrest_collision">
      <origin xyz="-0.34 0.00 0.72" rpy="0 0 0"/>
      <geometry>
        <box size="0.07 0.32 0.44"/>
      </geometry>
    </collision>
    <collision name="front_frame_collision">
      <origin xyz="0.34 0.00 0.25" rpy="0 0 0"/>
      <geometry>
        <box size="0.08 0.58 0.08"/>
      </geometry>
    </collision>
    <collision name="left_side_frame_collision">
      <origin xyz="0.02 0.30 0.32" rpy="0 0 0"/>
      <geometry>
        <box size="0.66 0.06 0.08"/>
      </geometry>
    </collision>
    <collision name="right_side_frame_collision">
      <origin xyz="0.02 -0.30 0.32" rpy="0 0 0"/>
      <geometry>
        <box size="0.66 0.06 0.08"/>
      </geometry>
    </collision>
  </link>

  <link name="left_rear_wheel">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="1.2"/>
      <inertia ixx="0.029" ixy="0.0" ixz="0.0" iyy="0.058" iyz="0.0" izz="0.029"/>
    </inertial>
    <collision>
      <origin xyz="0 0 0" rpy="1.57079632679 0 0"/>
      <geometry>
        <cylinder radius="0.31" length="0.045"/>
      </geometry>
    </collision>
  </link>

  <link name="right_rear_wheel">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="1.2"/>
      <inertia ixx="0.029" ixy="0.0" ixz="0.0" iyy="0.058" iyz="0.0" izz="0.029"/>
    </inertial>
    <collision>
      <origin xyz="0 0 0" rpy="1.57079632679 0 0"/>
      <geometry>
        <cylinder radius="0.31" length="0.045"/>
      </geometry>
    </collision>
  </link>

  <joint name="left_rear_wheel_joint" type="continuous">
    <origin xyz="-0.05 0.37 0.31" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="left_rear_wheel"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.02" friction="0.01"/>
  </joint>

  <joint name="right_rear_wheel_joint" type="continuous">
    <origin xyz="-0.05 -0.37 0.31" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="right_rear_wheel"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.02" friction="0.01"/>
  </joint>

  <link name="left_caster_yaw_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.2"/>
      <inertia ixx="0.0004" ixy="0.0" ixz="0.0" iyy="0.0004" iyz="0.0" izz="0.0004"/>
    </inertial>
  </link>

  <link name="right_caster_yaw_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.2"/>
      <inertia ixx="0.0004" ixy="0.0" ixz="0.0" iyy="0.0004" iyz="0.0" izz="0.0004"/>
    </inertial>
  </link>

  <joint name="left_caster_yaw_joint" type="continuous">
    <origin xyz="0.39 0.25 0.16" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="left_caster_yaw_link"/>
    <axis xyz="0 0 1"/>
    <dynamics damping="0.04" friction="0.01"/>
  </joint>

  <joint name="right_caster_yaw_joint" type="continuous">
    <origin xyz="0.39 -0.25 0.16" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="right_caster_yaw_link"/>
    <axis xyz="0 0 1"/>
    <dynamics damping="0.04" friction="0.01"/>
  </joint>

  <link name="left_front_caster">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.35"/>
      <inertia ixx="0.0007" ixy="0.0" ixz="0.0" iyy="0.0010" iyz="0.0" izz="0.0007"/>
    </inertial>
    <collision>
      <origin xyz="0 0 0" rpy="1.57079632679 0 0"/>
      <geometry>
        <cylinder radius="0.075" length="0.035"/>
      </geometry>
    </collision>
  </link>

  <link name="right_front_caster">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.35"/>
      <inertia ixx="0.0007" ixy="0.0" ixz="0.0" iyy="0.0010" iyz="0.0" izz="0.0007"/>
    </inertial>
    <collision>
      <origin xyz="0 0 0" rpy="1.57079632679 0 0"/>
      <geometry>
        <cylinder radius="0.075" length="0.035"/>
      </geometry>
    </collision>
  </link>

  <joint name="left_front_caster_joint" type="continuous">
    <origin xyz="0.00 0.00 -0.085" rpy="0 0 0"/>
    <parent link="left_caster_yaw_link"/>
    <child link="left_front_caster"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.02" friction="0.01"/>
  </joint>

  <joint name="right_front_caster_joint" type="continuous">
    <origin xyz="0.00 0.00 -0.085" rpy="0 0 0"/>
    <parent link="right_caster_yaw_link"/>
    <child link="right_front_caster"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.02" friction="0.01"/>
  </joint>

  <link name="left_handle_frame">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.01"/>
      <inertia ixx="0.00001" ixy="0.0" ixz="0.0" iyy="0.00001" iyz="0.0" izz="0.00001"/>
    </inertial>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.12 0.04 0.04"/>
      </geometry>
    </collision>
  </link>

  <link name="right_handle_frame">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.01"/>
      <inertia ixx="0.00001" ixy="0.0" ixz="0.0" iyy="0.00001" iyz="0.0" izz="0.00001"/>
    </inertial>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.12 0.04 0.04"/>
      </geometry>
    </collision>
  </link>

  <joint name="left_handle_frame_joint" type="fixed">
    <origin xyz="-0.40 0.24 0.92029" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="left_handle_frame"/>
  </joint>

  <joint name="right_handle_frame_joint" type="fixed">
    <origin xyz="-0.40 -0.24 0.92029" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="right_handle_frame"/>
  </joint>
</robot>
